# IRMS nginx site config — production.
# Copy to /etc/nginx/sites-available/irms and symlink to sites-enabled.
# Replace irms.example.ph with your domain; adjust root path and PHP-FPM socket.

# Rate-limit zones (set once at http{} scope in nginx.conf if you prefer).
limit_req_zone $binary_remote_addr zone=irms_api:10m rate=30r/s;
limit_req_zone $binary_remote_addr zone=irms_login:10m rate=5r/m;

# Upstream for Reverb WebSocket server.
upstream irms_reverb {
    server 127.0.0.1:8080;
    keepalive 32;
}

# Redirect HTTP → HTTPS.
server {
    listen 80;
    listen [::]:80;
    server_name irms.example.ph;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name irms.example.ph;

    root /var/www/irms/current/public;
    index index.php;

    charset utf-8;
    client_max_body_size 25M;

    # TLS (Let's Encrypt paths).
    ssl_certificate     /etc/letsencrypt/live/irms.example.ph/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/irms.example.ph/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # Security headers.
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(self), camera=(self), microphone=(self)" always;

    # Gzip.
    gzip on;
    gzip_vary on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;

    # Citizen reporting SPA (Vue) mounted at /citizen/ — assets are content-hashed.
    location ^~ /citizen/assets/ {
        expires 1y;
        access_log off;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # Citizen SPA history-mode fallback to its index.html.
    location ^~ /citizen/ {
        index index.html;
        try_files $uri /citizen/index.html;
    }

    # Reverb WebSocket passthrough. Reverb default path is /app (config: REVERB_SERVER_PATH).
    location ^~ /app/ {
        proxy_pass http://irms_reverb;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Reverb admin pusher endpoint passthrough.
    location = /apps {
        proxy_pass http://irms_reverb;
        proxy_set_header Host $host;
    }

    # Citizen API rate-limiting (defense in depth; Laravel RateLimiter also enforces).
    location ~ ^/api/ {
        limit_req zone=irms_api burst=60 nodelay;
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Login/2FA throttle at edge.
    location ~ ^/(login|two-factor-challenge) {
        limit_req zone=irms_login burst=10 nodelay;
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Default Laravel routing.
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # PHP-FPM handler.
    location ~ \.php$ {
        fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_hide_header X-Powered-By;
        fastcgi_read_timeout 120;
    }

    # Static asset caching (Vite outputs content-hashed filenames).
    location ~* ^/build/ {
        expires 1y;
        access_log off;
        add_header Cache-Control "public, immutable";
    }

    # PWA manifest and service worker must not be cached.
    location ~ ^/(sw\.js|manifest\.webmanifest|registerSW\.js)$ {
        expires off;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # Deny dotfiles and hidden paths.
    location ~ /\.(?!well-known).* {
        deny all;
    }

    access_log /var/log/nginx/irms.access.log;
    error_log  /var/log/nginx/irms.error.log;
}
