# =============================================================================
# IRMS PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# Copy to /var/www/irms/shared/.env and fill in ALL placeholders before first
# deploy. Values wrapped in <...> MUST be replaced. Never commit this file
# with real secrets.
#
# Generate a fresh key on the server: php artisan key:generate --show
# Generate VAPID pair: npx web-push generate-vapid-keys
# =============================================================================

APP_NAME=IRMS
APP_ENV=production
APP_KEY=<run: php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://<your-domain>

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging: stack → daily, keep 14 days, log warnings and above in prod.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# Database: PostgreSQL + PostGIS.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=irms
DB_USERNAME=irms
DB_PASSWORD=<strong-random-password>

# Sessions: HTTPS-only, encrypted, Redis-backed (database is also fine).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=<your-domain>
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# Redis: use a password on any shared/public infrastructure.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=<strong-random-password>
REDIS_PORT=6379

# Mail: production SMTP (Mailgun / SES / SendGrid). Never use `log` in prod.
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=<smtp.your-provider.com>
MAIL_PORT=587
MAIL_USERNAME=<smtp-username>
MAIL_PASSWORD=<smtp-password>
MAIL_FROM_ADDRESS=noreply@<your-domain>
MAIL_FROM_NAME="${APP_NAME}"

# Reverb WebSocket server. behind nginx TLS termination, keep http internally.
# Clients connect over wss:// on 443 — nginx proxies to 127.0.0.1:8080.
REVERB_APP_ID=<random-id>
REVERB_APP_KEY=<random-32-char-key>
REVERB_APP_SECRET=<random-64-char-secret>
REVERB_HOST=<your-domain>
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_ALLOWED_ORIGINS=<your-domain>
REVERB_SCALING_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Mapbox public token. Restrict allowed URLs in the Mapbox dashboard to your domain(s).
VITE_MAPBOX_TOKEN=<mapbox-public-token>

# Web Push (browser notifications). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<public-key>
VAPID_PRIVATE_KEY=<private-key>
VAPID_SUBJECT=mailto:cdrrmo@butuan.gov.ph
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# CORS: exact domain list. Citizen reporter app origins go here.
CORS_ALLOWED_ORIGINS=https://<your-domain>,https://<report-subdomain>
CORS_SUPPORTS_CREDENTIALS=true
CORS_MAX_AGE=3600

# Trusted proxies: "*" if behind Cloudflare; otherwise list your LB IPs.
TRUSTED_PROXIES=*

# Horizon dashboard — restrict by hostname if you want a separate subdomain.
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# Sentry (optional but strongly recommended).
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
