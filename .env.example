APP_NAME=IRMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Production: stack + daily, level=warning (or info), LOG_DAILY_DAYS=14.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# Dev uses sqlite; production targets PostgreSQL + PostGIS.
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=irms
# DB_USERNAME=irms
# DB_PASSWORD=

# Production MUST set SESSION_SECURE_COOKIE=true and SESSION_DOMAIN to your cookie domain.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production: use a real SMTP provider (Mailgun, SES, SendGrid) and a domain-matched FROM address.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Reverb: in production set REVERB_SCHEME=https, REVERB_PORT=443, REVERB_HOST to your domain,
# and restrict REVERB_ALLOWED_ORIGINS to comma-separated hosts (e.g. "irms.butuan.gov.ph").
REVERB_APP_ID=your-reverb-app-id
REVERB_APP_KEY=your-reverb-key
REVERB_APP_SECRET=your-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=*
REVERB_SCALING_ENABLED=false
# REVERB_TLS_CERT=/etc/ssl/certs/reverb.crt
# REVERB_TLS_KEY=/etc/ssl/private/reverb.key

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Generate per environment: php artisan webpush:vapid (or manually with web-push CLI).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:cdrrmo@butuan.gov.ph
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# CORS: comma-separated origins or "*" (dev only). Production MUST list explicit hosts.
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_ORIGINS_PATTERNS=
CORS_SUPPORTS_CREDENTIALS=false
CORS_MAX_AGE=0

# Trusted proxies: "*" to trust all (e.g. behind Cloudflare), or comma-separated IPs/CIDRs of your load balancer.
TRUSTED_PROXIES=

# Horizon dashboard hosting; blank keeps it under APP_URL/horizon.
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# Sentry error reporting — leave DSN blank to disable. In production set a real DSN.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
